# =============================================================================
# Engram — example environment configuration
# =============================================================================
# Copy this file to .env and adjust the values for your environment:
#     cp .env.example .env
#
# Values here are SAFE PLACEHOLDERS intended for local development only.
# CHANGE every password and review every setting before any production use.
# Never commit your real .env (it is gitignored).
#
# Two variable families are used:
#   POSTGRES_*  — consumed by docker-compose.yml to initialize Postgres and to
#                 build the service's ENGRAM_DATABASE_URL.
#   ENGRAM_*    — consumed directly by the Engram service (see engram/config.py).
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL (docker-compose.yml reads these)
# -----------------------------------------------------------------------------
# Two roles are used for defense-in-depth tenant isolation:
#
#   OWNER role  — the table-owning superuser. Runs migrations
#                 (``engram init-db``), the first-key bootstrap
#                 (``engram bootstrap-key``), cross-tenant CLI scans
#                 (``promote-proposed`` / ``backfill-embeddings``), and backups.
#                 It bypasses RLS so it can see every tenant.
#
#   APP role    — the non-owner role the service connects as at RUNTIME. It owns
#                 no tables and has no BYPASSRLS, so Postgres RLS enforces tenant
#                 isolation even if the app forgets a WHERE clause. Created by
#                 migrations/003_app_role_and_force_rls.sql; its password is set
#                 on FIRST BOOT by migrations/app_role_password.sh.
#
# On FIRST BOOT ONLY (empty data volume), Postgres's docker-entrypoint-initdb.d
# runs the bundled migrations + password script using these credentials. After
# that the passwords are fixed — to change one, alter the running DB and these
# values together.
#
# *** CHANGE BOTH PASSWORDS FOR ANY NON-LOCAL DEPLOYMENT. ***
POSTGRES_DB=engram
# Owner/migration role:
POSTGRES_OWNER_USER=engram
POSTGRES_OWNER_PASSWORD=change-me-in-production
# Non-owner application role (runtime):
POSTGRES_APP_USER=engram_app
POSTGRES_APP_PASSWORD=change-me-in-production

# Host/port Postgres listens on, exposed to the host. For production, consider
# binding to 127.0.0.1 only or removing the port mapping and keeping Postgres
# on the Compose internal network. See docker-compose.yml.
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432


# -----------------------------------------------------------------------------
# Engram service core
# -----------------------------------------------------------------------------
# Log level for the API server and worker: debug | info | warning | error
ENGRAM_LOG_LEVEL=info

# Auth toggle. With auth DISABLED (false), every request runs as the seeded
# default/admin principal with full scopes — convenient for local dev, UNSAFE
# for production. Enable auth (true) and create a key with `engram bootstrap-key`.
ENGRAM_AUTH_ENABLED=false

# New-format API keys (eng_<key_id>_<secret>) are verified by an O(1) indexed
# lookup + constant-time digest check. Successfully resolved keys are cached
# in-process for this many seconds so repeated requests skip the lookup.
# Revocation takes effect after at most this TTL. Set to 0 to disable caching.
# ENGRAM_API_KEY_CACHE_TTL_SECONDS=60
# Safety cap on cached principals per process (default 4096).
# ENGRAM_API_KEY_CACHE_MAX_SIZE=4096


# -----------------------------------------------------------------------------
# Database URLs (Engram service)
# -----------------------------------------------------------------------------
# docker-compose.yml builds both URLs for the service from POSTGRES_* above, so
# you do NOT normally set them here when using Compose:
#
#   ENGRAM_DATABASE_URL        -> the APP role (runtime, RLS-enforced).
#   ENGRAM_OWNER_DATABASE_URL  -> the OWNER role (migrations/admin, RLS bypass).
#
# Set these ONLY for non-Compose deployments (bare metal / venv), where the
# service connects directly. The scheme MUST be postgresql+asyncpg:// (the
# SQLAlchemy async dialect). Runtime should point at the non-owner app role;
# the owner URL is used by `engram init-db`, `engram bootstrap-key`, and the
# cross-tenant CLI commands. When ENGRAM_OWNER_DATABASE_URL is unset it falls
# back to ENGRAM_DATABASE_URL (single-role dev/test).
#
# ENGRAM_DATABASE_URL=postgresql+asyncpg://engram_app:change-me-in-production@localhost:5432/engram
# ENGRAM_OWNER_DATABASE_URL=postgresql+asyncpg://engram:change-me-in-production@localhost:5432/engram

# Optional read-oriented database URL (ENG-AUD-011 / F18). When set, startup
# recall's bounded candidate selection reads through this connection instead
# of ENGRAM_DATABASE_URL — point it at a read replica once one exists. Same
# app-role credentials/RLS posture as ENGRAM_DATABASE_URL is expected. Unset
# (the default) falls back to ENGRAM_DATABASE_URL, so this is safe to leave
# unset until a replica exists. Writes (promotion, item events, job enqueue,
# recall telemetry) never use this connection.
# ENGRAM_READ_DATABASE_URL=


# -----------------------------------------------------------------------------
# Embeddings (semantic recall / search)
# -----------------------------------------------------------------------------
# Provider: "none" (defer embeddings — recall works without them), "openai".
# To enable semantic recall, set provider to "openai" and supply OPENAI_API_KEY,
# then run `engram backfill-embeddings` to populate existing memories.
# Default vector dimension matches text-embedding-3-small (1536).
ENGRAM_EMBEDDING_PROVIDER=none
ENGRAM_EMBEDDING_DIM=1536
# Embedding model name. Used as the default for embedding profile creation.
ENGRAM_EMBEDDING_MODEL=text-embedding-3-small
# Ready-coverage percentage required by `embedding-profiles activate`.
ENGRAM_EMBEDDING_ACTIVATION_COVERAGE_THRESHOLD=95.0
# API key for the embedding provider. Leave empty for provider=none.
# Required when provider=openai.
ENGRAM_OPENAI_API_KEY=
# Base URL for OpenAI-compatible embedding providers (OpenRouter, DeepInfra,
# etc.). Leave unset for the default OpenAI API (api.openai.com).
# ENGRAM_OPENAI_BASE_URL=https://openrouter.ai/api/v1


# -----------------------------------------------------------------------------
# Classification (auto-classify memories on write)
# -----------------------------------------------------------------------------
# Provider: "none" (rule-based fallback only), "openai".
# When "openai", classification uses the model below with a confidence gate.
#
# As of ENG-AUD-008, the synchronous /v1/remember path runs RULE-BASED
# classification only (never OpenAI). The OpenAI LLM refinement runs later as
# an async classification.refine job (see "Background worker" below).
ENGRAM_CLASSIFICATION_PROVIDER=none
ENGRAM_CLASSIFICATION_MODEL=gpt-4o-mini
ENGRAM_CLASSIFICATION_CONFIDENCE_THRESHOLD=0.5
# Dedicated API key for classification. When set, used instead of
# ENGRAM_OPENAI_API_KEY — allows classification on a different provider
# (e.g. DeepInfra) while embeddings use OpenRouter.
# ENGRAM_CLASSIFICATION_API_KEY=
# Dedicated base URL for classification. Falls back to ENGRAM_OPENAI_BASE_URL.
# ENGRAM_CLASSIFICATION_BASE_URL=
# Minimum confidence delta before a classification.refine job records a change
# (idempotency guard against oscillation). 0.0 applies any improvement.
# ENGRAM_CLASSIFICATION_REFINE_MIN_DELTA=0.0

# Hermes lifecycle storage gate: retain dispositions at/above this retention
# confidence are remembered as proposed. The old PROMOTE name is deprecated.
# ENGRAM_HOOKS_STORE_THRESHOLD=0.65
# ENGRAM_HOOKS_PROMOTE_THRESHOLD=0.65


# -----------------------------------------------------------------------------
# Write-path cost control
# -----------------------------------------------------------------------------
# When true, successful embedding generation enqueues a semantic conflict.check
# job that compares the new item against existing active memories (duplicate /
# refine / contradict detection). When false, low-trust writes defer conflict
# checking to the promotion path. Propagated to both API and worker.
# ENGRAM_CONFLICT_CHECK_ON_WRITE=true


# -----------------------------------------------------------------------------
# Usage / metering telemetry (ENG-METER-001)
# -----------------------------------------------------------------------------
# Append-only, privacy-preserving observability for dogfood usage/cost
# economics (see docs/usage-metering.md). Never gates or throttles a request;
# a telemetry insert failure is logged and swallowed. Off by default for the
# open-source/self-hosted distribution — enable explicitly for dogfood/
# operator deployments. Propagated to both API and worker (classification,
# embeddings, and conflict detection all run provider calls from the worker).
# ENGRAM_USAGE_TELEMETRY_ENABLED=false


# -----------------------------------------------------------------------------
# Background worker + job queue (ENG-AUD-008)
# -----------------------------------------------------------------------------
# /v1/remember moves expensive work off the request path: it creates the
# embedding placeholder and an embedding.generate job (no inline OpenAI call),
# and (when kind is omitted) runs rule-based classification only. A worker
# processes the queue: embedding.generate → conflict.check, plus async LLM
# classification refinement and promotion/retention hooks.
#
# The standard Docker Compose stack (docker compose up -d) starts a long-lived
# worker container automatically. The API and worker share the same provider
# and database configuration via Compose environment variables.
#
# As of ENG-AUD-011, startup recall also enqueues a recall.telemetry job
# (last_recalled_at / recall_count / startup_recall_count updates, moved off
# the synchronous read path). Without a worker running, those counters lag —
# recall itself is unaffected since it no longer depends on them being current.
#
# For ad-hoc or one-shot processing without the Compose worker:
#   docker compose exec engram-service engram worker --once
#
# Worker tunables (propagated to the Compose worker container at runtime;
# no image rebuild required):
# Seconds between claim attempts in the poll loop (--once ignores this).
# ENGRAM_JOB_POLL_INTERVAL_SECONDS=2
# Per-job retry ceiling before a job is marked dead.
# ENGRAM_JOB_MAX_ATTEMPTS=5
# A running job whose lock is older than this (seconds) is reclaimed as stale
# (worker crash recovery).
# ENGRAM_JOB_LEASE_STALE_AFTER_SECONDS=300

# Classification vocabulary cache (F20). In-process TTL cache so the six
# DISTINCT vocab scans run at most once per window per tenant. Set to 0 to
# disable caching (every classify() rescans — useful in tests).
# ENGRAM_VOCAB_CACHE_TTL_SECONDS=120
# Safety cap on the number of cached tenant vocab entries (LRU eviction).
# ENGRAM_VOCAB_CACHE_MAX_TENANTS=256


# -----------------------------------------------------------------------------
# Recall defaults (optional tuning — defaults shown)
# -----------------------------------------------------------------------------
# ENGRAM_RECALL_BYTE_BUDGET=4096
# ENGRAM_RECALL_ITEM_BUDGET=50
# ENGRAM_MAX_PINNED_TOKENS=2048
# ENGRAM_STALE_AFTER_DAYS=90

# Cap on proposed items scanned per lazy startup-recall promotion pass
# (POST /v1/recall mode=startup). Keeps startup recall bounded regardless of
# how large a tenant's proposed backlog grows.
# ENGRAM_STARTUP_PROMOTION_LIMIT=20
# Top-k plausible active-item candidates considered by the promotion-time
# conflict recheck.
# ENGRAM_PROMOTION_CONFLICT_CANDIDATE_K=5

# Bounded SQL candidate selection for startup recall (ENG-AUD-011 / F18).
# Postgres selects at most this many candidate rows (across diversified
# sub-pools: coarse score, freshest, highest-importance, least-recently-
# recalled, plus pinned items fetched separately); Python's detailed scorer
# then runs only over that bounded set instead of the whole eligible corpus.
# Clamped to [recall_item_budget, ENGRAM_STARTUP_RECALL_CANDIDATE_LIMIT_MAX] —
# callers cannot raise this through the public recall API.
# ENGRAM_STARTUP_RECALL_CANDIDATE_LIMIT=500
# Hard safety cap on the above, regardless of misconfiguration.
# ENGRAM_STARTUP_RECALL_CANDIDATE_LIMIT_MAX=5000


# -----------------------------------------------------------------------------
# Backups (deploy/backup.sh reads these — optional)
# -----------------------------------------------------------------------------
# Directory for pg_dump output (created if missing). Default: ./backups
# BACKUP_DIR=./backups
# Delete backups older than this many days. Set to 0 to keep all. Default: 14
# BACKUP_RETENTION_DAYS=14
# Override pg_dump connection if it differs from POSTGRES_* (host:port).
# Format: host:port   e.g. 127.0.0.1:5432
# BACKUP_PGHOST=
